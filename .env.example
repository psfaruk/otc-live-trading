# Copy to .env for local dev. On Railway, set these as Variables in the
# dashboard instead of committing a .env file (never commit real credentials).

QX_EMAIL=
QX_PASSWORD=
# Optional — leave blank to auto-detect
QX_UA=
# Optional — cross-platform temp cache dir for pyquotex; leave blank to use
# the OS default temp dir
QX_ROOT=

# Multi-viewer safety net (see feed.py _AssetStream manager) — optional,
# defaults shown. QX_MAX_STREAMS defaults to 45 to comfortably cover the
# always-on forex pairs (see QX_PAYOUT_FLOOR below) plus on-demand extras.
QX_MAX_STREAMS=45
QX_STAGGER_GAP_SEC=1.5

# Minimum live 1-minute payout % a forex pair needs to be streamable at all.
# Pairs at or above this run continuously from server boot (always-on);
# pairs below it are blocked from opening entirely. Optional — defaults to
# 81 (Quotex's own "worth trading" cutoff).
QX_PAYOUT_FLOOR=81

# Optional — point the SQLite DB at a Railway persistent Volume so
# candle_micro.db survives redeploys (e.g. /data/candle_micro.db). Leave
# blank for local dev (defaults to a file next to db.py).
QX_DB_PATH=

# Per-user accounts (email + password, 3 categories: normal/premium/admin)
# gate the whole site — see server.py's auth_middleware.
#
# REQUIRED for real deployments: signs the session cookie. Must be a
# stable random string YOU set (e.g. `python -c "import secrets;
# print(secrets.token_hex(32))"`) — if unset, a random secret is generated
# per process, which logs everyone out on every restart/redeploy (this app
# redeploys often, so this matters more here than in most apps).
SESSION_SECRET=

# Comma-separated emails that get 'admin' category automatically on
# signup/login (re-synced every login — see db.py's verify_login). Admin
# gets everything 'premium' gets plus the dashboard in the Settings tab.
# Removing an email from this list does NOT demote an existing admin —
# only the admin dashboard's own category control does that.
ADMIN_EMAILS=

# Railway injects this automatically — do not set manually
# PORT=
